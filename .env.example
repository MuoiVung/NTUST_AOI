# .env.example
# Copy this file to .env and adjust the values for your environment.

# --------------------------
# API & Network Configuration
# --------------------------

# The URL of the actual Factory MES / Shopfloor System
# Used to check if the serial number is valid before running the machine.
# For local simulation, use: http://127.0.0.1:9090/ashx/WebAPI/Board/SerialTest/HandlerGetSerialInfo.ashx
SHOPFLOOR_API_URL=http://your_shopfloor_ip:port/path/to/api

# PostgreSQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
